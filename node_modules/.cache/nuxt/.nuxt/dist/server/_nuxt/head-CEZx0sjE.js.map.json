aderCount\">\n              No data found.\n            </UiTableData>\n          </UiTableRow>\n        </template>\n        <template v-else>\n          <slot name=\"body\" />\n        </template>\n      </tbody>\n      <slot name=\"foot\" />\n    </table>\n  </UiTableContainer>\n</template>\n","<template>\n  <th\n    v-bind=\"$attrs\"\n    class=\"px-6 py-2 text-left border-y text-dashboard-neutral-400 border-dashboard-neutral-100/50 bg-dashboard-neutral-100/10 font-medium text-sm whitespace-nowrap\"\n  >\n    <slot />\n  </th>\n</template>\n"],"version":3}