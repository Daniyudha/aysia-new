{"file":"index-BVAKrG6s.js","mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AACW,QAAA,WAAAA,eAAAC,WAAA,EAAA,OAAM,wCAAoC,MAAA,CAAA,CAAA,iOAAA;;;;;;;;;;;;;;;;;;ACArD,UAAM,QAAQ;AAId,UAAM,EAAqB,mBAAA,IAAuB,eAAA;;;QAe7C,eAAaC,KAAAA,OAAO;AAAA,QACrB,MAAK;AAAA,QACL,MAAK;AAAA,QACL,iBAAc;AAAA,QACb,kBAAgB,MAAM,UAAUC,MAAA,kBAAA,GAAoB;AAAA,QACpD,UAAiB,MAAM,UAAUA,MAAA,kBAAA,GAAoB,WAAQ,IAAA;AAAA,QAG9D,QAAM,4GAA0G;AAAA,qCAC7D,MAAM,UAAUA,MAAA,kBAAA,GAAoB;AAAA,QAAA;;;;;;;;;;;;;;;;;;;;;AC1B3F,UAAM,QAAQ;AAMd,UAAM,CAAC,UAAU,QAAQ,IAAI,iBAAA;AAC7B,UAAM,gBAAgB,IAAI,KAAK;AAC/B,UAAM,gBAAgB,IAAI,KAAK;AAsB/B,UAAM,qBAAqB,SAAS,MAAM;AAExC,aAAO,MAAM,WACV,MAAA,EACA,UACA,IAAI,CAAA,cAAa;AAAA,QAChB,MAAM,SAAS;AAAA,QACf,OAAO,SAAS;AAAA,MAAA,EAChB;AAAA,IACN,CAAC;;;;mBAIMH,eAAAC,WAAA,EAAA,OAAM,0DAAA,GAAyD,MAAA,CAAA,sHAKpDE,MAAA,aAAA,CAAa,IAAA,cAAA;AAGnB,YAAAC,mBAAA,iBAAA,EAAA,MAAK,qCAAiC,MAAA,OAAA,CAAA;;AAOrBC,oBAAAF,MAAA,kBAAA,IAAZ,aAAQ;;;UAKO,OAAO,SAAS;AAAA,QAAA;2BAAtC,CAEsB,GAAAG,QAAAC,UAAA,aAAA;;AADjBD,qBAAA,GAAAE,eAAA,SAAS,IAAI,CAAA,EAAA;AAAA;;gBAAbC,gBAAAC,gBAAA,SAAS,IAAI,GAAA,CAAA;AAAA,cAAA;AAAA;;;;;;oIAUVP,MAAA,aAAA,CAAa,IAAA,cAAA,EAAA,mBAAA;;QAGnB,MAAK;AAAA,QAAkC,OAAM;AAAA,MAAA;;;;;;;;;;;;;;;;;;;;;ACzEzD,UAAM,QAAQ;AAKd,UAAM,mBAAmB,SAAS,MAA2B;AAC3D,YAAM,SAA8B,CAAA;AACpC,YAAM,OAAO,MAAM;AAEnB,eAAS,IAAI,GAAG,IAAI,MAAM,YAAY,QAAQ,KAAK,MAAM;AACvD,eAAO,KAAK,MAAM,YAAY,MAAM,GAAG,IAAI,IAAI,CAAC;AAAA,MAClD;AAEA,aAAO;AAAA,IACT,CAAC;;;UAKgB,QAAA,SAAO;;AAIJE,sBAAA,IAAL,MAAC;;;;AAkBIA,sBAAA,IAAP,QAAG;;AAOUA,wBAAA,QAAA,aAAP,QAAG;;;;;;MAgBL,WAAA,CAAA,QAAA,YAAY,QAAM;AAAE,cAAA,KAAAL,eAAAC,WAAA,EAAA,OAAM,+BAA2B,MAAA,CAAA,CAAA,4CAAA;AAAA;;sBAStC,QAAA,aAAW,CAA3B,MAAM,UAAK;;;YAOZ,IAAE,EAAA,MAAA,uBAAA,QAAA,EAAA,WAAsD,KAAK,KAAE;AAAA,YAChE,OAAM;AAAA,UAAA;6BAFR,CAoBW,GAAAK,QAAAC,UAAA,aAAA;;4CAfN,OAAG,IAAKI,sBAAAA,OAAAA,KAAAA,mBAAAA,MAAAA,gBAAAA,GAAAA,EAAmB,OAAO,OAAO,GAAG,KAAK,SAAS,EAAA,kBAC1D,OAAK,KAAK,KAAK,yJAIbH,eAAA,KAAK,qBAAqB,iOAQ1BA,eAAA,KAAK,KAAK;;;kBAdfI,YAIC,OAAA;AAAA,oBAHE,KAAG,IAAKD,sBAAAA,OAAAA,KAAAA,mBAAAA,MAAAA,gBAAAA,GAAAA,EAAmB,OAAO,OAAO,GAAG,KAAK,SAAS;AAAA,oBAC1D,KAAK,KAAK;AAAA,oBACX,OAAM;AAAA,kBAAA;kBAERC,YAEI,OAFD,OAAM,kCAAA,GAAiCF,gBACrC,KAAK,qBAAqB,GAAA,CAAA;AAAA,kBAE/BE,YAOI,OANF,OAAM,qLAAA,GAGyBF,gBAE5B,KAAK,KAAK,GAAA,CAAA;AAAA,gBAAA;AAAA;;;;;;;sBAUWP,MAAA,gBAAA,GAAgB,CAA1C,gBAAgB,UAAK;;wBAOK,gBAAc,CAAlC,MAAM,cAAS;;;cAKpB,IAAE,EAAA,MAAA,uBAAA,QAAA,EAAA,WAAsD,KAAK,KAAE;AAAA,cAChE,OAAM;AAAA,YAAA;+BAFR,CAoBW,GAAAG,QAAAC,UAAA,aAAA;;8CAfN,OAAG,IAAKI,sBAAAA,OAAAA,KAAAA,mBAAAA,MAAAA,gBAAAA,GAAAA,EAAmB,OAAO,OAAO,GAAG,KAAK,SAAS,EAAA,kBAC1D,OAAK,KAAK,KAAK,qLAIbH,eAAA,KAAK,qBAAqB,iOAQ1BA,eAAA,KAAK,KAAK;;;oBAdfI,YAIC,OAAA;AAAA,sBAHE,KAAG,oFAAwB,OAAO,OAAO,GAAG,KAAK,SAAS;AAAA,sBAC1D,KAAK,KAAK;AAAA,sBACX,OAAM;AAAA,oBAAA;oBAERA,YAEI,OAFD,OAAM,gDAAA,GAA+CF,gBACnD,KAAK,qBAAqB,GAAA,CAAA;AAAA,oBAE/BE,YAOI,OANF,OAAM,qLAAA,GAGyBF,gBAE5B,KAAK,KAAK,GAAA,CAAA;AAAA,kBAAA;AAAA;;;;;;;;;;;;;;;;;;;;;;;;;;;;ACtIC,mBAAA;;;uBAUnBV,eAAAC,WAAA,EAAA,OAAM,UAAM,MAAA,CAAA,+GAIFC,sBAAAA,KAAAA,QAAQ,gBAAW,CAAA,IAAA,cAAA;;QAM5B,MAAK;AAAA,QACL,OAAM;AAAA,QACN,QAAO;AAAA,MAAA;uDAEkCM,eAAA,QAAA,wBAAwB,QAAA,cAAW,CAAA,uEAG3E,QAAA,WAAW,6BAIHN,sBAAAA,KAAAA,QAAQ,gBAAgBA,KAAAA,QAAQ,UAAU,IAAA,cAAA,4JAIVM,eAAA,QAAA,gBAAgB,QAAA,aAAa,QAAA,aAAa,QAAA,cAAW,CAAA;;QAE9F,MAAK;AAAA,QACL,OAAM;AAAA,QACN,OAAM;AAAA,QACN,QAAO;AAAA,MAAA;;;;;;;;;;;;;;;;AC7CnB,YAAQ;AAAA,MACN,OAAO;AAAA,MACP,MAAM;AAAA,QACJ;AAAA,UACE,MAAM;AAAA,UACN,SACE;AAAA,QAAA;AAAA,QAEJ;AAAA,UACE,MAAM;AAAA,UACN,SAAS;AAAA,QAAA;AAAA,QAEX;AAAA,UACE,MAAM;AAAA,UACN,SAAS;AAAA,QAAA;AAAA,MACX;AAAA,IACF,CACD;AAED,UAAM,EAAE,oBAAoB,kBAAA,IAAsB,eAAA;AAClD,UAAM,EAAE,SAAS;AAAA,MACf;AAAA,MACA,MAAM,gBAAA,EAAkB,IAAI,EAAE;AAAA,MAC9B;AAAA,QACE,MAAM;AAAA,MAAA;AAAA,IACR;AAIF,UAAM,gBAAgB,IAAI,KAAK;AAC/B,UAAM,CAAC,oBAAoB,IAAI,GAAG,CAAC,CAAC,OAAO,UAAU,MAAM;AACzD,UAAI,cAAc;AAChB;AACF,UAAI,YAAY,QAAQ,CAAC,MAAM,UAAU;AACvC,cAAM,gBAAgB,WAAW,KAAK,KAAK,CAAC,QAAa,IAAI,SAAS,OAAO;AAC7E,YAAI,eAAe;AACjB,wBAAc,QAAQ;AACtB,4BAAkB,EAAE,UAAU,cAAc,GAAA,CAAI;AAAA,QAClD;AAAA,MACF;AAAA,IACF,GAAG,EAAE,WAAW,MAAM;AAEtB,UAAM,EAAE,MAAM,UAAU,SAAS,gBAAA,IAAoB,aAAa,gBAAgB,mBAAmB,OAAO,QAAQ,IAAI,mBAAmB,OAAO,IAAI,IAAI,MAAM;AAC9J,YAAM,WAAW,mBAAmB,MAAM;AAC1C,YAAM,cAAc,oBAAoB,OAAO,OAAO,OAAO,oBAAoB,OAAO,IAAI,IAAI;AAChG,UAAI,UAAU;AACZ,eAAO,eAAA,EAAiB,gBAAgB,UAAU,SAAA,GAAY,EAAE,OAAO,GAAG,MAAM,aAAa;AAAA,MAC/F,OACK;AACH,eAAO,eAAA,EAAiB,OAAO,EAAE,OAAO,GAAG,MAAM,aAAa;AAAA,MAChE;AAAA,IACF,GAAG;AAAA,MACD,OAAO,CAAC,kBAAkB;AAAA,MAC1B,MAAM;AAAA,IAAA,CACP;;;;;;;;QAKc,gBAAX,CAEW,GAAAF,QAAAC,UAAA,aAAA;;;cADa,YAAYJ,MAAA,IAAA,GAAM;AAAA,YAAA;;;cAAxCS,YAAgD,gCAAA;AAAA,gBAA1B,YAAYT,MAAA,IAAA,GAAM;AAAA,cAAA;;;;;;;QAGpB,aAAaA,MAAA,QAAA,GAAU,QAAI,CAAA;AAAA,QAAS,SAASA,MAAA,eAAA;AAAA,MAAA;;QACjD,eAAaA,MAAA,QAAA,GAAU,cAAU;AAAA,QAAQ,gBAAcA,2BAAoB,OAAO,OAAOA,MAAA,kBAAA,GAAoB,IAAI,IAAA;AAAA,MAAA;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","$props","_unref","_ssrRenderComponent","_ssrRenderList","_push","_parent","_ssrInterpolate","_createTextVNode","_toDisplayString","useRuntimeConfig","_createVNode"],"sources":["../../../../../../../app/components/gallery/header.vue","../../../../../../../app/components/gallery/filter-button.vue","../../../../../../../app/components/gallery/header-filter.vue","../../../../../../../app/components/gallery/collection-grid.vue","../../../../../../../app/components/gallery/pagination.vue","../../../../../../../app/pages/portfolio/index.vue"],"sourcesContent":["<template>\n  <section class=\"py-4 border-y border-app-secondary\">\n    <div class=\"app-container\">\n      <div class=\"flex flex-col md:flex-row justify-between items-center\">\n        <h1 class=\"font-fraunces text-app-secondary text-5xl font-normal leading-[100%]\">\n          Portfolio\n        </h1>\n        <div class=\"w-full md:w-6/12\">\n          <slot name=\"filter\" />\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nconst props = defineProps<{\n  value: string;\n}>();\n\nconst { updateQueryParams, currentQueryParams } = useQueryParams();\n\nfunction applyFilter() {\n  if (!props.value) {\n    return;\n  }\n  updateQueryParams({\n    category: props.value !== \"all\" ? props.value : undefined,\n    page: 1,\n  });\n}\n</script>\n\n<template>\n  <button\n    :data-filter=\"$props.value\"\n    role=\"tab\"\n    type=\"button\"\n    aria-controls=\"content-area\"\n    :aria-selectedd=\"props.value === currentQueryParams?.category\"\n    :tabindex=\"\n      props.value === currentQueryParams?.category ? 0 : -1\n    \"\n    class=\"font-fraunces text-app-secondary px-2 text-lg transition-all duration-300 cursor-pointer hover:underline\"\n    :class=\"{\n      'font-semibold underline':\n        props.value === currentQueryParams?.category,\n    }\"\n    @click=\"applyFilter\"\n  >\n    <slot />\n  </button>\n</template>\n","<script lang=\"ts\" setup>\nimport emblaCarouselVue from \"embla-carousel-vue\";\n\nconst props = withDefaults(defineProps<{\n  categories?: GalleryCategoryResponse[];\n}>(), {\n  categories: () => [] as GalleryCategoryResponse[],\n});\n\nconst [emblaRef, emblaApi] = emblaCarouselVue();\nconst canScrollPrev = ref(false);\nconst canScrollNext = ref(false);\n\nfunction updateButtonStates(emblaApi: EmblaCarouselAPIType) {\n  canScrollPrev.value = emblaApi.canScrollPrev();\n  canScrollNext.value = emblaApi.canScrollNext();\n}\n\nonMounted(() => {\n  if (!emblaApi.value)\n    return;\n  updateButtonStates(emblaApi.value);\n  emblaApi.value.on(\"select\", updateButtonStates);\n});\n\nfunction scrollNext() {\n  emblaApi.value?.scrollNext();\n}\n\nfunction scrollPrev() {\n  emblaApi.value?.scrollPrev();\n}\n\nconst computedCategories = computed(() => {\n  // Remove \"All\" option and reverse order to match admin display\n  return props.categories\n    .slice()\n    .reverse()\n    .map(category => ({\n      name: category.name,\n      value: category.id,\n    }));\n});\n</script>\n\n<template>\n  <div class=\"w-[98%] mx-auto flex gap-2 items-center justify-between\">\n    <!-- Tombol kiri -->\n    <button\n      type=\"button\"\n      class=\"inline-flex disabled:opacity-50 items-center\"\n      :disabled=\"!canScrollPrev\"\n      @click=\"scrollPrev\"\n    >\n      <Icon name=\"heroicons:chevron-left-16-solid\" />\n    </button>\n\n    <!-- Carousel kategori -->\n    <div ref=\"emblaRef\" class=\"filter-embla overflow-hidden relative w-full\">\n      <div class=\"filter-embla__container flex\" role=\"tablist\">\n        <div\n          v-for=\"category in computedCategories\"\n          :key=\"category.value\"\n          class=\"filter-embla__slide flex-shrink-0 px-2 py-1\"\n          role=\"presentation\"\n        >\n          <GalleryFilterButton :value=\"category.value\">\n            {{ category.name }}\n          </GalleryFilterButton>\n        </div>\n      </div>\n    </div>\n\n    <!-- Tombol kanan -->\n    <button\n      type=\"button\"\n      class=\"inline-flex disabled:opacity-50 items-center\"\n      :disabled=\"!canScrollNext\"\n      @click=\"scrollNext\"\n    >\n      <Icon name=\"heroicons:chevron-left-16-solid\" class=\"rotate-180\" />\n    </button>\n  </div>\n</template>\n\n<style scoped>\n.filter-embla {\n  position: relative;\n  overflow: hidden;\n  width: 100%;\n}\n\n.filter-embla__container {\n  display: flex;\n  gap: 8px;\n  align-items: center;\n  transition: transform 0.3s ease;\n}\n\n.filter-embla__slide {\n  flex: 0 0 auto;\n}\n\n/* pastikan tidak terpengaruh hero */\n.filter-embla__slide img,\n.filter-embla__slide button {\n  box-shadow: none !important;\n  border: none !important;\n  background: none !important;\n}\n\n/* Hilangkan efek border / background */\n:deep(.GalleryFilterButton) {\n  background: transparent !important;\n  box-shadow: none !important;\n  border: none !important;\n}\n</style>\n","<script setup lang=\"ts\">\ntype Props = {\n  collections: JourneyResponse[];\n  chunckSize?: number;\n  pending?: boolean;\n};\n\nconst props = withDefaults(defineProps<Props>(), {\n  chunckSize: 2,\n  pending: false,\n});\n\nconst groupedGalleries = computed((): JourneyResponse[][] => {\n  const groups: JourneyResponse[][] = [];\n  const size = props.chunckSize;\n\n  for (let i = 0; i < props.collections.length; i += size) {\n    groups.push(props.collections.slice(i, i + size));\n  }\n\n  return groups;\n});\n</script>\n\n<template>\n  <!-- ================= SKELETON ================= -->\n  <section v-if=\"pending\">\n    <!-- MOBILE -->\n    <div class=\"md:hidden\">\n      <div\n        v-for=\"i in 3\"\n        :key=\"i\"\n        class=\"border-b py-8\"\n      >\n        <div class=\"app-container\">\n          <div class=\"collection-grid\">\n            <div class=\"flex flex-col items-end w-full\">\n              <div class=\"skeleton-image mb-3\" />\n              <div class=\"skeleton-line w-32 mb-2\" />\n              <div class=\"skeleton-line w-64 h-6\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- DESKTOP -->\n    <div\n      v-for=\"row in 2\"\n      :key=\"row\"\n      class=\"grouped-collection-row hidden md:block\"\n    >\n      <div class=\"app-container\">\n        <div class=\"collection-grid\">\n          <div\n            v-for=\"col in chunckSize\"\n            :key=\"col\"\n            class=\"collection-grid-item\"\n          >\n            <div class=\"flex flex-col items-end w-full\">\n              <div class=\"skeleton-image-square mb-3\" />\n              <div class=\"skeleton-line w-32 mb-2\" />\n              <div class=\"skeleton-line w-72 h-7\" />\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <!-- ================= EMPTY STATE ================= -->\n  <p v-else-if=\"!collections.length\" class=\"text-center text-3xl my-6\">\n    No galleries found.\n  </p>\n\n  <!-- ================= REAL CONTENT ================= -->\n  <section v-else>\n    <!-- MOBILE -->\n    <div class=\"md:hidden\">\n      <div\n        v-for=\"(item, index) in collections\"\n        :key=\"index\"\n        class=\"border-b py-8\"\n      >\n        <div class=\"app-container\">\n          <div class=\"collection-grid\">\n            <NuxtLink\n              :to=\"{ name: 'portfolio-galleryId', params: { galleryId: item.id } }\"\n              class=\"group flex flex-col items-end w-full text-app-secondary\"\n            >\n              <img\n                :src=\"`${useRuntimeConfig().public.apiBase}${item.thumbnail}`\"\n                :alt=\"item.title\"\n                class=\"w-full h-auto object-cover object-top mb-3\"\n              >\n              <p class=\"text-base font-light text-right\">\n                {{ item.gallery_category_name }}\n              </p>\n              <p\n                class=\"font-serif font-medium text-3xl text-right relative\n                       after:absolute after:left-0 after:bottom-0 after:right-0\n                       after:h-1 after:bg-app-secondary after:hidden\n                       group-hover:after:block\"\n              >\n                {{ item.title }}\n              </p>\n            </NuxtLink>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- DESKTOP -->\n    <div\n      v-for=\"(groupedGallery, index) in groupedGalleries\"\n      :key=\"index\"\n      class=\"grouped-collection-row hidden md:block\"\n    >\n      <div class=\"app-container\">\n        <div class=\"collection-grid\">\n          <div\n            v-for=\"(item, indexItem) in groupedGallery\"\n            :key=\"indexItem\"\n            class=\"collection-grid-item\"\n          >\n            <NuxtLink\n              :to=\"{ name: 'portfolio-galleryId', params: { galleryId: item.id } }\"\n              class=\"group flex flex-col items-end w-full text-app-secondary\"\n            >\n              <img\n                :src=\"`${useRuntimeConfig().public.apiBase}${item.thumbnail}`\"\n                :alt=\"item.title\"\n                class=\"w-full h-auto object-cover object-top mb-3 aspect-square\"\n              >\n              <p class=\"text-base font-light text-right font-franuces\">\n                {{ item.gallery_category_name }}\n              </p>\n              <p\n                class=\"font-medium font-serif text-4xl text-right relative\n                       after:absolute after:left-0 after:bottom-0 after:right-0\n                       after:h-1 after:bg-app-secondary after:hidden\n                       group-hover:after:block\"\n              >\n                {{ item.title }}\n              </p>\n            </NuxtLink>\n          </div>\n        </div>\n      </div>\n    </div>\n  </section>\n</template>\n\n<style scoped>\n@reference \"../../assets/css/main.css\";\n\n/* EXISTING */\n.grouped-collection-row {\n  @apply border-b;\n}\n.collection-grid {\n  @apply grid grid-cols-1 md:grid-cols-2;\n}\n.collection-grid > .collection-grid-item {\n  @apply py-10 flex odd:justify-end md:odd:pr-10 md:even:pl-10 md:odd:border-r;\n}\n\n/* ================= SKELETON ================= */\n.skeleton-image {\n  width: 100%;\n  height: 260px;\n  border-radius: 8px;\n  background: linear-gradient(100deg, #e5e5e5 40%, #f2f2f2 50%, #e5e5e5 60%);\n  background-size: 200% 100%;\n  animation: shimmer 1.4s infinite;\n}\n\n.skeleton-image-square {\n  width: 100%;\n  aspect-ratio: 1 / 1;\n  border-radius: 8px;\n  background: linear-gradient(100deg, #e5e5e5 40%, #f2f2f2 50%, #e5e5e5 60%);\n  background-size: 200% 100%;\n  animation: shimmer 1.4s infinite;\n}\n\n.skeleton-line {\n  height: 16px;\n  border-radius: 6px;\n  background: linear-gradient(100deg, #e0e0e0 40%, #f2f2f2 50%, #e0e0e0 60%);\n  background-size: 200% 100%;\n  animation: shimmer 1.4s infinite;\n}\n\n@keyframes shimmer {\n  to {\n    background-position: -200% 0;\n  }\n}\n</style>\n","<script lang=\"ts\" setup>\nconst props = withDefaults(defineProps<{\n  currentPage?: number;\n  totalPages?: number;\n}>(), {\n  currentPage: 1,\n  totalPages: 1,\n});\n\nconst { updateQueryParams } = useQueryParams();\n\nfunction goToPage(page: number) {\n  if (page < 1 || page > props?.totalPages)\n    return;\n  updateQueryParams({ page });\n}\n</script>\n\n<template>\n  <section class=\"py-5\">\n    <div class=\"app-container text-app-secondary\">\n      <div class=\"flex items-center justify-between gap-4\">\n        <button\n          :disabled=\"$props?.currentPage === 1\"\n          type=\"button\"\n          class=\"inline-flex gap-[0.25rem] items-center cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed\"\n          @click=\"goToPage(currentPage - 1)\"\n        >\n          <Icon\n            name=\"heroicons:arrow-left-20-solid\"\n            width=\"20\"\n            height=\"20\"\n          />\n          <span class=\"inline-block text-xl\">Page {{ currentPage === 1 ? 1 : currentPage - 1 }}</span>\n        </button>\n        <p class=\"text-[1.75rem] font-bold\">\n          {{ currentPage }}\n        </p>\n        <button\n          type=\"button\"\n          :disabled=\"$props?.currentPage === $props?.totalPages\"\n          class=\"inline-flex gap-[0.25rem] items-center cursor-pointer disabled:opacity-60 disabled:cursor-not-allowed\"\n          @click=\"goToPage(currentPage + 1)\"\n        >\n          <span class=\"inline-block text-xl\">Page {{ currentPage === totalPages ? totalPages : currentPage + 1 }}</span>\n          <Icon\n            name=\"heroicons:arrow-left-20-solid\"\n            class=\"rotate-180\"\n            width=\"20\"\n            height=\"20\"\n          />\n        </button>\n      </div>\n    </div>\n  </section>\n</template>\n","<script setup lang=\"ts\">\nimport { categoryFetcher } from \"~/repository/modules/category\";\nimport { journeyFetcher } from \"~/repository/modules/journey\";\n\nuseHead({\n  title: \"Aysia LinggarWati - Portfolio\",\n  meta: [\n    {\n      name: \"description\",\n      content:\n        \"Welcome to the official website of Aysia LinggarWati, where creativity meets elegance. Explore our portfolio and discover the essence of our work.\",\n    },\n    {\n      name: \"keywords\",\n      content: \"Aysia LinggarWati, portfolio, creative, design, elegance\",\n    },\n    {\n      name: \"viewport\",\n      content: \"width=device-width, initial-scale=1\",\n    },\n  ],\n});\n\nconst { currentQueryParams, updateQueryParams } = useQueryParams();\nconst { data } = useAsyncData(\n  \"journey_categories\",\n  () => categoryFetcher().get({}),\n  {\n    lazy: true,\n  },\n);\n\n// Set default filter to \"Human\" if no category is selected\nconst isInitialized = ref(false);\nwatch([currentQueryParams, data], ([query, categories]) => {\n  if (isInitialized.value)\n    return;\n  if (categories?.data && !query.category) {\n    const humanCategory = categories.data.find((cat: any) => cat.name === \"Human\");\n    if (humanCategory) {\n      isInitialized.value = true;\n      updateQueryParams({ category: humanCategory.id });\n    }\n  }\n}, { immediate: true });\n\nconst { data: journeys, pending: journeysPending } = useAsyncData(`journey-list-${currentQueryParams.value?.category}-${currentQueryParams.value?.page}`, () => {\n  const category = currentQueryParams.value.category;\n  const currentPage = currentQueryParams?.value?.page ? Number(currentQueryParams?.value?.page) : 1;\n  if (category) {\n    return journeyFetcher().getByCategoryId(category?.toString(), { limit: 9, page: currentPage });\n  }\n  else {\n    return journeyFetcher().getAll({ limit: 9, page: currentPage });\n  }\n}, {\n  watch: [currentQueryParams],\n  lazy: true,\n});\n</script>\n\n<template>\n  <GalleryHeader>\n    <template #filter>\n      <GalleryHeaderFilter :categories=\"data?.data\" />\n    </template>\n  </GalleryHeader>\n  <GalleryCollectionGrid :collections=\"journeys?.data ?? []\" :pending=\"journeysPending\" />\n  <GalleryPagination :total-pages=\"journeys?.totalPages ?? 1\" :current-page=\"currentQueryParams?.page ? Number(currentQueryParams?.page) : 1\" />\n</template>\n"],"version":3}